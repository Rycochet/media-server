# These three you need to make yourself
/.env
/.env.keep-alive
/compose.override.yaml

# In case someone installs on a dedicaed partition
/aquota.user
# Because global .gitignore is too hard for many
/.vscode
# If using the overlay script to merge
/overlay-tools-*.sh
# Developing containers locally
/*/src

# Docker data folders that want to exist with the correct permissions
/*/*/**
!/*/*/.gitkeep
!/*/*/*/.gitkeep
